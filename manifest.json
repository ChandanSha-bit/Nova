{
  "manifest_version": 3,
  "name": "Nova",
  "version": "1.0.0",
  "description": "Secure vault for notes, links, images, and PDFs with calculator disguise mode",
  "permissions": [
    "storage"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Nova - Secure Vault"
  },
  "background": {
    "service_worker": "background.js"
  }
}
